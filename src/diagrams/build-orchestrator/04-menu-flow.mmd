    SINGLE -- "Yes" --> SCOPE{"Module scope"}

    SCOPE -- "All modules" --> RUN["build_family()"]
    SCOPE -- "Cherry-pick" --> PICK["Pick modules by number;\nunselected reuse staged .hex"]
    PICK --> RUN
