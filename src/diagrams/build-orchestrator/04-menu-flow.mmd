    FAMQ -- "C" --> CLEAN["Clean menu\n(old builds, staged hex, logs)\nconfirm each delete"]
    CLEAN --> FAMQ

    FAMQ -- "0 (build all)" --> MAT
    FAMQ -- "single family" --> MAT

    MAT{"Pick a maturity\nSQA / Field Trial / Production"}
