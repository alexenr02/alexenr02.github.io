---
// Homepage
// Main landing page with all sections

import BaseLayout from '@layouts/BaseLayout.astro';
import About from '@components/sections/About.astro';
import Skills from '@components/sections/Skills.astro';
import WorkExperience from '@components/sections/WorkExperience.astro';
import Contact from '@components/sections/Contact.astro';
import { SITE } from '@lib/constants';
---

<BaseLayout>
  <!-- Hero Section -->
  <section
    id="home"
    class="flex min-h-[calc(100vh-5rem)] items-center justify-center bg-gradient-to-b from-background to-card px-4"
  >
    <div class="container mx-auto text-center">
      <h1 class="mb-4 text-5xl font-bold text-foreground md:text-6xl lg:text-7xl">
        Alejandro Enriquez
      </h1>
      <p class="mb-8 text-xl text-secondary md:text-2xl">Embedded Software Engineer</p>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-secondary">
        {SITE.description}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="#contact"
          class="hover:bg-primary/90 rounded-lg bg-primary px-6 py-3 font-medium text-white transition-colors"
        >
          Get in Touch
        </a>
        <a
          href="#projects"
          class="rounded-lg border border-border px-6 py-3 font-medium text-foreground transition-colors hover:bg-card"
        >
          View Projects
        </a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <About />

  <!-- Skills Section -->
  <Skills />

  <!-- Work Experience Section -->
  <WorkExperience />

  <!-- Projects Section (Placeholder) -->
  <section id="projects" class="scroll-mt-20 bg-card py-section">
    <div class="container mx-auto px-4">
      <h2 class="mb-8 text-3xl font-bold text-foreground md:text-4xl">Projects</h2>
      <p class="text-lg text-secondary">Project showcase will be implemented in Phase 3.</p>
    </div>
  </section>

  <!-- Lab/Experiments Section (Placeholder) -->
  <section id="lab" class="scroll-mt-20 py-section">
    <div class="container mx-auto px-4">
      <h2 class="mb-8 text-3xl font-bold text-foreground md:text-4xl">Lab & Experiments</h2>
      <p class="text-lg text-secondary">Interactive experiments will be added in Phase 4.</p>
    </div>
  </section>

  <!-- Contact Section -->
  <Contact />
</BaseLayout>
