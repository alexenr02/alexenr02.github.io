---
// Privacy Policy Page
// Documents actual data handling for this static portfolio

import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@lib/constants';
---

<BaseLayout title="Privacy Policy" description="Privacy policy and data handling information">
  <div class="container mx-auto max-w-4xl px-4 py-12">
    <h1 class="mb-4 text-4xl font-bold text-foreground">Privacy Policy</h1>
    <p class="mb-8 text-sm text-secondary">
      Last updated: {
        new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
      }
    </p>

    <div class="prose prose-gray max-w-none dark:prose-invert">
      <section class="mb-8">
        <h2 class="mb-4 text-2xl font-semibold text-foreground">Introduction</h2>
        <p class="text-secondary">
          This privacy policy explains how this website collects, uses, and protects your personal
          information. I am committed to transparency and protecting your privacy.
        </p>
      </section>

      <section class="mb-8">
        <h2 class="mb-4 text-2xl font-semibold text-foreground">Data Collection</h2>
        <p class="mb-4 text-secondary">This website collects minimal data to function properly:</p>

        <h3 class="mb-2 text-xl font-semibold text-foreground">Analytics</h3>
        <ul class="mb-4 list-disc space-y-2 pl-6 text-secondary">
          <li>
            This site does not use any analytics service. No pageview tracking, no cookies, no
            personal data collected for analytics.
          </li>
        </ul>

        <h3 class="mb-2 text-xl font-semibold text-foreground">Contact</h3>
        <ul class="mb-4 list-disc space-y-2 pl-6 text-secondary">
          <li>
            Contact is handled via direct email to {SITE.email}. No contact form submissions are
            stored on any third-party server by this site.
          </li>
        </ul>

        <h3 class="mb-2 text-xl font-semibold text-foreground">Error tracking</h3>
        <ul class="mb-4 list-disc space-y-2 pl-6 text-secondary">
          <li>
            No client-side error tracking service is currently enabled. If that changes, this page
            will be updated first.
          </li>
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="mb-4 text-2xl font-semibold text-foreground">Local storage</h2>
        <ul class="list-disc space-y-2 pl-6 text-secondary">
          <li>
            <strong>Theme preference:</strong> localStorage (not a cookie) stores your dark/light
            mode choice so the site remembers it on the next visit.
          </li>
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="mb-4 text-2xl font-semibold text-foreground">Your Rights</h2>
        <p class="mb-4 text-secondary">You have the right to:</p>
        <ul class="list-disc space-y-2 pl-6 text-secondary">
          <li>Clear your browser's localStorage to reset the theme preference</li>
          <li>
            Contact me about any personal data you sent by email (for example, asking me to delete
            a message I received)
          </li>
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="mb-4 text-2xl font-semibold text-foreground">Third-Party Services</h2>
        <p class="mb-4 text-secondary">This website uses the following third-party services:</p>
        <ul class="list-disc space-y-2 pl-6 text-secondary">
          <li>
            <strong>GitHub Pages:</strong> Hosting — <a
              href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement"
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary hover:underline">Privacy Statement</a
            >
          </li>
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="mb-4 text-2xl font-semibold text-foreground">Changes to This Policy</h2>
        <p class="text-secondary">
          This privacy policy may be updated from time to time. The "Last updated" date at the top
          of this page will reflect any changes.
        </p>
      </section>

      <section>
        <h2 class="mb-4 text-2xl font-semibold text-foreground">Contact</h2>
        <p class="text-secondary">
          For privacy-related questions or concerns, please email: <a
            href={`mailto:${SITE.email}`}
            class="text-primary hover:underline">{SITE.email}</a
          >
        </p>
      </section>
    </div>
  </div>
</BaseLayout>
