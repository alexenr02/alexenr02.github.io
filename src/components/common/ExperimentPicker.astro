---
// Reusable floating experiment picker (fonts, card styles, etc.)

interface Option {
  id: string;
  label: string;
}

interface Props {
  title: string;
  storageKey: string;
  param: string;
  attr: string;
  defaultId: string;
  options: Option[];
  /** stack offset so multiple pickers don't overlap */
  stack?: number;
  surface?: 'dark' | 'light' | 'none';
}

const { title, storageKey, param, attr, defaultId, options, stack = 0, surface = 'none' } =
  Astro.props;

const ids = options.map((o) => o.id);
---

<div
  class="exp-picker"
  style={`bottom: ${1 + stack * 12.5}rem`}
  data-exp-picker
  data-storage-key={storageKey}
  data-param={param}
  data-attr={attr}
  data-default-id={defaultId}
  data-surface={surface}
  data-ids={ids.join(',')}
>
  <p class="exp-picker__title">{title}</p>
  <div class="exp-picker__list">
    {
      options.map((opt, i) => (
        <button type="button" class="exp-picker__btn" data-exp-id={opt.id}>
          <span class="exp-picker__num">{i + 1}</span>
          {opt.label}
        </button>
      ))
    }
  </div>
</div>

<script>
  function initPicker(root: HTMLElement) {
    if (root.dataset.bound === 'true') return;
    root.dataset.bound = 'true';

    const storageKey = root.dataset.storageKey!;
    const param = root.dataset.param!;
    const attr = root.dataset.attr!;
    const defaultId = root.dataset.defaultId!;
    const allowed = new Set((root.dataset.ids || '').split(',').filter(Boolean));
    const surfaceMode = root.dataset.surface || 'none';

    function readId(): string {
      const fromUrl = new URLSearchParams(window.location.search).get(param);
      if (fromUrl && allowed.has(fromUrl)) return fromUrl;
      const stored = sessionStorage.getItem(storageKey);
      if (stored && allowed.has(stored)) return stored;
      return defaultId;
    }

    function apply(id: string) {
      document.documentElement.setAttribute(attr, id);
      if (surfaceMode === 'dark') {
        document.documentElement.dataset.heroSurface = 'dark';
      } else if (surfaceMode === 'light') {
        document.documentElement.dataset.heroSurface = 'light';
      }

      sessionStorage.setItem(storageKey, id);
      root.querySelectorAll('[data-exp-id]').forEach((el) => {
        if (!(el instanceof HTMLElement)) return;
        el.classList.toggle('is-active', el.dataset.expId === id);
      });

      const url = new URL(window.location.href);
      url.searchParams.set(param, id);
      history.replaceState(null, '', `${url.pathname}?${url.searchParams.toString()}`);
    }

    root.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const btn = target.closest('[data-exp-id]');
      if (!(btn instanceof HTMLElement) || !btn.dataset.expId) return;
      event.preventDefault();
      apply(btn.dataset.expId);
    });

    apply(readId());
  }

  function initAll() {
    document.querySelectorAll('[data-exp-picker]').forEach((el) => {
      if (el instanceof HTMLElement) initPicker(el);
    });
  }

  initAll();
  document.addEventListener('astro:page-load', initAll);
</script>

<style>
  .exp-picker {
    position: fixed;
    right: 1rem;
    z-index: 60;
    width: min(15.5rem, calc(100vw - 2rem));
    max-height: min(42vh, 20rem);
    overflow-y: auto;
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    padding: 0.75rem;
    box-shadow: 0 12px 40px rgba(17, 50, 75, 0.18);
    backdrop-filter: blur(12px);
  }

  .exp-picker__title {
    margin-bottom: 0.5rem;
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-secondary);
  }

  .exp-picker__list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .exp-picker__btn {
    display: flex;
    width: 100%;
    align-items: center;
    gap: 0.5rem;
    border: none;
    border-radius: 0.65rem;
    background: transparent;
    padding: 0.4rem 0.5rem;
    font-family: inherit;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-text);
    text-align: left;
    cursor: pointer;
  }

  .exp-picker__btn:hover {
    background: var(--color-card-bg);
  }

  .exp-picker__btn.is-active {
    background: var(--color-primary);
    color: #fff;
  }

  .exp-picker__num {
    display: inline-flex;
    width: 1.2rem;
    height: 1.2rem;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: color-mix(in srgb, currentColor 12%, transparent);
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.6rem;
  }
</style>
