---
// Footer component
// Contains copyright, social links, and privacy policy link

import { SITE, SOCIAL_LINKS } from '@lib/constants';
import { Github, Linkedin, Mail } from 'lucide-svelte';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-background py-12">
  <div class="container mx-auto px-4">
    <div class="grid gap-8 md:grid-cols-3">
      <!-- About Column -->
      <div>
        <h3 class="mb-4 text-lg font-bold text-foreground">
          {SITE.name}
        </h3>
        <p class="text-sm text-secondary">
          Embedded Software Engineer specializing in industrial, automotive, and refrigeration
          systems.
        </p>
      </div>

      <!-- Quick Links Column -->
      <div>
        <h3 class="mb-4 text-lg font-bold text-foreground">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/#about" class="text-secondary transition-colors hover:text-primary"> About</a>
          </li>
          <li>
            <a href="/#projects" class="text-secondary transition-colors hover:text-primary">
              Projects
            </a>
          </li>
          <li>
            <a href="/#experience" class="text-secondary transition-colors hover:text-primary">
              Work Experience
            </a>
          </li>
          <li>
            <a href="/#contact" class="text-secondary transition-colors hover:text-primary">
              Contact
            </a>
          </li>
        </ul>
      </div>

      <!-- Social Links Column -->
      <div>
        <h3 class="mb-4 text-lg font-bold text-foreground">Connect</h3>
        <div class="flex gap-4">
          <a
            href={SOCIAL_LINKS.github}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg p-2 text-foreground transition-colors hover:bg-gray-200 hover:text-primary dark:hover:bg-gray-800"
            aria-label="GitHub profile"
          >
            <Github class="h-5 w-5" aria-hidden="true" />
          </a>
          <a
            href={SOCIAL_LINKS.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg p-2 text-foreground transition-colors hover:bg-gray-200 hover:text-primary dark:hover:bg-gray-800"
            aria-label="LinkedIn profile"
          >
            <Linkedin class="h-5 w-5" aria-hidden="true" />
          </a>
          <a
            href={`mailto:${SITE.email}`}
            class="rounded-lg p-2 text-foreground transition-colors hover:bg-gray-200 hover:text-primary dark:hover:bg-gray-800"
            aria-label="Send email"
          >
            <Mail class="h-5 w-5" aria-hidden="true" />
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div
      class="mt-8 flex flex-col items-center justify-between gap-4 border-t border-border pt-8 text-sm text-secondary md:flex-row"
    >
      <p>
        &copy; {currentYear}
        {SITE.name}. All rights reserved.
      </p>
      <div class="flex gap-4">
        <a href="/privacy" class="transition-colors hover:text-primary"> Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
