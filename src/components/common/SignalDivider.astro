---
// Schematic section divider — Option B motif, Rokid colors

interface Props {
  label?: string;
}

const { label = '' } = Astro.props;
---

<div class="signal-divider" aria-hidden="true">
  <div class="signal-divider__line"></div>
  {label && <span class="signal-divider__label">{label}</span>}
  <svg class="signal-divider__wave" viewBox="0 0 120 12" preserveAspectRatio="none">
    <path
      d="M0 6 H20 L28 2 L36 10 L44 2 L52 10 L60 6 H120"
      fill="none"
      stroke="currentColor"
      stroke-width="1.25"
    />
  </svg>
  <div class="signal-divider__line"></div>
</div>

<style>
  .signal-divider {
    display: grid;
    grid-template-columns: 1fr auto auto 1fr;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1rem 0;
    color: var(--color-signal);
    opacity: 0.85;
  }

  .signal-divider__line {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-border),
      color-mix(in srgb, var(--color-signal) 55%, var(--color-border)),
      var(--color-border),
      transparent
    );
  }

  .signal-divider__label {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    color: var(--color-secondary);
  }

  .signal-divider__wave {
    width: 4.5rem;
    height: 0.7rem;
  }

  @media (max-width: 640px) {
    .signal-divider {
      grid-template-columns: 1fr auto 1fr;
    }

    .signal-divider__wave {
      display: none;
    }
  }
</style>
