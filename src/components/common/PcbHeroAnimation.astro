---
// Animated PCB hero — large central MCU, signal pulses along copper traces

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

// LQFP-style MCU centered in the 640×480 viewBox
const view = { w: 640, h: 480 };
const mcu = { cx: view.w / 2, cy: view.h / 2, size: 112, pins: 12 };
const mcuOriginX = mcu.cx - mcu.size / 2;
const mcuOriginY = mcu.cy - mcu.size / 2;
const pinSpan = mcu.size - 20;
const pinStep = pinSpan / (mcu.pins - 1);
const pinOffset = 10;

const pinY = (i: number) => mcuOriginY + pinOffset + i * pinStep;
const pinX = (i: number) => mcuOriginX + pinOffset + i * pinStep;

// Trace endpoints keyed to MCU pin rows
const traces = {
  xtal: `M ${pinX(5)} ${mcuOriginY} V 92 H 138 V 62`,
  can: `M ${pinX(9)} ${mcuOriginY} H 456 V 52 H 522`,
  usb: `M ${mcuOriginX + mcu.size} ${pinY(6)} H 492 V 392 H 546`,
  ldo: `M ${pinX(5)} ${mcuOriginY + mcu.size} V 368 H 158 V 412`,
  debug: `M ${mcuOriginX} ${pinY(2)} H 88 V ${pinY(2)} H 48`,
  caps: `M ${mcuOriginX} ${pinY(8)} H 84 V 318 H 40`,
  reg: `M ${mcuOriginX + mcu.size} ${pinY(3)} H 472 V 112 H 516`,
  passives: `M ${pinX(2)} ${mcuOriginY + mcu.size} H 192 V 342 H 114`,
};
---

<figure class:list={['pcb-hero', className]} aria-label="Animated microcontroller PCB with signal traces">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 640 480"
    class="pcb-hero__svg"
    role="img"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="pcb-board" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#143d28" />
        <stop offset="40%" stop-color="#1a5236" />
        <stop offset="100%" stop-color="#0b2418" />
      </linearGradient>
      <linearGradient id="pcb-copper" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#6b4e1a" />
        <stop offset="35%" stop-color="#d4a82a" />
        <stop offset="65%" stop-color="#f0c850" />
        <stop offset="100%" stop-color="#6b4e1a" />
      </linearGradient>
      <linearGradient id="pcb-copper-under" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#3d2e10" />
        <stop offset="100%" stop-color="#2a1f0a" />
      </linearGradient>
      <linearGradient id="mcu-body" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#2a2a2a" />
        <stop offset="18%" stop-color="#121212" />
        <stop offset="55%" stop-color="#080808" />
        <stop offset="100%" stop-color="#1e1e1e" />
      </linearGradient>
      <linearGradient id="mcu-die" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#1a1a1a" />
        <stop offset="100%" stop-color="#0a0a0a" />
      </linearGradient>
      <linearGradient id="pin-gold" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#e8c84a" />
        <stop offset="45%" stop-color="#b8922a" />
        <stop offset="100%" stop-color="#8a6918" />
      </linearGradient>
      <radialGradient id="pcb-vignette" cx="50%" cy="50%" r="70%">
        <stop offset="0%" stop-color="#2d6b48" stop-opacity="0.25" />
        <stop offset="100%" stop-color="#000000" stop-opacity="0.65" />
      </radialGradient>
      <radialGradient id="pcb-spotlight" cx="50%" cy="50%" r="42%">
        <stop offset="0%" stop-color="#ffffff" stop-opacity="0.06" />
        <stop offset="100%" stop-color="#ffffff" stop-opacity="0" />
      </radialGradient>
      <filter id="pcb-texture" x="0%" y="0%" width="100%" height="100%">
        <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="3" seed="4" result="noise" />
        <feColorMatrix type="saturate" values="0" in="noise" result="gray" />
        <feBlend in="SourceGraphic" in2="gray" mode="multiply" />
      </filter>
      <filter id="mcu-shadow" x="-30%" y="-30%" width="160%" height="160%">
        <feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="#000" flood-opacity="0.55" />
      </filter>
      <filter id="pcb-glow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="2" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <filter id="pcb-signal-glow" x="-100%" y="-100%" width="300%" height="300%">
        <feGaussianBlur stdDeviation="3.5" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <!-- Board base -->
    <g filter="url(#pcb-texture)">
      <rect x="20" y="20" width="600" height="440" rx="16" fill="url(#pcb-board)" />
      <rect x="20" y="20" width="600" height="440" rx="16" fill="url(#pcb-vignette)" />
      <rect x="20" y="20" width="600" height="440" rx="16" fill="url(#pcb-spotlight)" />
      <rect
        x="20"
        y="20"
        width="600"
        height="440"
        rx="16"
        fill="none"
        stroke="#256b45"
        stroke-width="1.5"
        opacity="0.5"
      />
    </g>

    <!-- Via grid -->
    <g opacity="0.14" fill="#4caf7a">
      {
        Array.from({ length: 12 }).map((_, row) =>
          Array.from({ length: 16 }).map((_, col) => (
            <circle cx={48 + col * 34} cy={48 + row * 34} r="1.2" />
          )),
        )
      }
    </g>

    <!-- Copper underlayer (wider, darker) -->
    <g
      fill="none"
      stroke="url(#pcb-copper-under)"
      stroke-width="4.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      opacity="0.5"
    >
      <path d={traces.xtal} />
      <path d={traces.can} />
      <path d={traces.usb} />
      <path d={traces.ldo} />
      <path d={traces.debug} />
      <path d={traces.caps} />
      <path d={traces.reg} />
      <path d={traces.passives} />
    </g>

    <!-- Top copper traces -->
    <g
      fill="none"
      stroke="url(#pcb-copper)"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
      opacity="0.92"
    >
      <path d={traces.xtal} />
      <path d={traces.can} />
      <path d={traces.usb} />
      <path d={traces.ldo} />
      <path d={traces.debug} />
      <path d={traces.caps} />
      <path d={traces.reg} />
      <path d={traces.passives} />
    </g>

    <!-- Solder pads at trace bends and endpoints -->
    <g fill="#c9a227" opacity="0.35">
      <circle cx="138" cy="62" r="4" />
      <circle cx="522" cy="52" r="4" />
      <circle cx="546" cy="392" r="4" />
      <circle cx="158" cy="412" r="4" />
      <circle cx="48" cy={pinY(2)} r="3.5" />
      <circle cx="40" cy="318" r="3.5" />
      <circle cx="516" cy="112" r="3.5" />
      <circle cx="114" cy="342" r="3.5" />
    </g>

    <!-- Crystal (HC-49 style) -->
    <g transform="translate(108, 36)">
      <ellipse cx="30" cy="14" rx="28" ry="12" fill="#111" opacity="0.4" />
      <rect x="4" y="4" width="52" height="20" rx="2" fill="#1a1a1a" stroke="#555" stroke-width="0.8" />
      <rect x="10" y="7" width="40" height="14" rx="1" fill="url(#mcu-die)" />
      <rect x="0" y="0" width="8" height="28" rx="1" fill="url(#pin-gold)" />
      <rect x="52" y="0" width="8" height="28" rx="1" fill="url(#pin-gold)" />
      <text x="30" y="38" text-anchor="middle" fill="#ffffff" opacity="0.22" font-size="8" font-family="monospace">Y1 16MHz</text>
    </g>

    <!-- CAN transceiver SOIC-8 -->
    <g transform="translate(502, 36)">
      <rect x="0" y="0" width="52" height="32" rx="1.5" fill="#0a0a0a" stroke="#3a3a3a" stroke-width="0.8" />
      <rect x="4" y="4" width="44" height="24" rx="1" fill="#111" />
      {
        [0, 1, 2, 3].map((i) => (
          <>
            <rect x={-6} y={6 + i * 6.5} width="6" height="2.5" rx="0.4" fill="url(#pin-gold)" />
            <rect x={52} y={6 + i * 6.5} width="6" height="2.5" rx="0.4" fill="url(#pin-gold)" />
          </>
        ))
      }
      <text x="26" y="20" text-anchor="middle" fill="#ffffff" opacity="0.28" font-size="7" font-family="monospace">U2</text>
    </g>

    <!-- USB-C connector -->
    <g transform="translate(518, 372)">
      <rect x="0" y="0" width="64" height="36" rx="4" fill="#141414" stroke="#555" stroke-width="1" />
      <rect x="8" y="8" width="48" height="20" rx="3" fill="#0a0a0a" stroke="#333" stroke-width="0.5" />
      <rect x="26" y="12" width="12" height="12" rx="2" fill="#222" />
    </g>

    <!-- SWD debug header -->
    <g transform={`translate(32, ${pinY(2) - 40})`}>
      <rect x="0" y="0" width="24" height="80" rx="2" fill="#0f0f0f" stroke="#444" stroke-width="0.8" />
      {
        [0, 1, 2, 3, 4, 5].map((i) => (
          <circle cx="12" cy={10 + i * 12} r="2.8" fill="url(#pin-gold)" stroke="#6b5218" stroke-width="0.3" />
        ))
      }
    </g>

    <!-- 0603 capacitor bank -->
    <g transform={`translate(28, ${pinY(8) + 24})`}>
      {
        [0, 1, 2, 3, 4].map((i) => (
          <g transform={`translate(${i * 16}, 0)`}>
            <rect x="0" y="2" width="2" height="6" rx="0.3" fill="url(#pin-gold)" />
            <rect x="10" y="2" width="2" height="6" rx="0.3" fill="url(#pin-gold)" />
            <rect x="2" y="0" width="8" height="10" rx="0.5" fill="#1e3a8a" stroke="#2563eb" stroke-width="0.4" />
          </g>
        ))
      }
    </g>

    <!-- LDO SOT-223 -->
    <g transform="translate(134, 400)">
      <rect x="0" y="0" width="48" height="36" rx="2" fill="#0a0a0a" stroke="#3a3a3a" stroke-width="0.8" />
      <rect x="14" y="4" width="20" height="22" rx="1" fill="#111" />
      <rect x="0" y="10" width="10" height="16" rx="1" fill="url(#pin-gold)" />
      <rect x="38" y="10" width="10" height="16" rx="1" fill="url(#pin-gold)" />
      <rect x="16" y="28" width="16" height="8" rx="1" fill="url(#pin-gold)" />
    </g>

    <!-- 0805 resistors -->
    <g transform="translate(96, 334)">
      {
        [0, 1, 2, 3].map((i) => (
          <g transform={`translate(${i * 20}, 0)`}>
            <rect x="0" y="3" width="2" height="6" rx="0.3" fill="url(#pin-gold)" />
            <rect x="14" y="3" width="2" height="6" rx="0.3" fill="url(#pin-gold)" />
            <rect x="2" y="1" width="12" height="10" rx="0.5" fill="#2a2010" stroke="#5c4a28" stroke-width="0.4" />
            <rect x="4" y="4" width="2" height="4" fill="#8b4513" />
            <rect x="7" y="4" width="2" height="4" fill="#111" />
            <rect x="10" y="4" width="2" height="4" fill="#8b4513" />
          </g>
        ))
      }
    </g>

    <!-- MCU package (large LQFP) -->
    <g transform={`translate(${mcuOriginX}, ${mcuOriginY})`} filter="url(#mcu-shadow)">
      <!-- Pin 1 chamfer -->
      <path d="M 0 0 H 18 L 0 18 Z" fill="#1a1a1a" opacity="0.9" />

      <!-- Leads with solder fillets -->
      <g fill="url(#pin-gold)" stroke="#6b5218" stroke-width="0.25">
        {
          Array.from({ length: mcu.pins }).map((_, i) => (
            <>
              <rect
                x={-14}
                y={pinOffset + i * pinStep - 1.5}
                width="14"
                height="3"
                rx="0.4"
                class="pcb-pin"
                style={`animation-delay: ${i * 0.06}s`}
              />
              <ellipse
                cx={-1}
                cy={pinOffset + i * pinStep}
                rx="2.5"
                ry="1.8"
                fill="#b8922a"
                opacity="0.7"
              />
              <rect
                x={mcu.size}
                y={pinOffset + i * pinStep - 1.5}
                width="14"
                height="3"
                rx="0.4"
                class="pcb-pin"
                style={`animation-delay: ${0.15 + i * 0.06}s`}
              />
              <ellipse
                cx={mcu.size + 1}
                cy={pinOffset + i * pinStep}
                rx="2.5"
                ry="1.8"
                fill="#b8922a"
                opacity="0.7"
              />
              <rect
                x={pinOffset + i * pinStep - 1.5}
                y={-14}
                width="3"
                height="14"
                rx="0.4"
                class="pcb-pin"
                style={`animation-delay: ${0.3 + i * 0.06}s`}
              />
              <ellipse
                cx={pinOffset + i * pinStep}
                cy={-1}
                rx="1.8"
                ry="2.5"
                fill="#b8922a"
                opacity="0.7"
              />
              <rect
                x={pinOffset + i * pinStep - 1.5}
                y={mcu.size}
                width="3"
                height="14"
                rx="0.4"
                class="pcb-pin"
                style={`animation-delay: ${0.45 + i * 0.06}s`}
              />
              <ellipse
                cx={pinOffset + i * pinStep}
                cy={mcu.size + 1}
                rx="1.8"
                ry="2.5"
                fill="#b8922a"
                opacity="0.7"
              />
            </>
          ))
        }
      </g>

      <!-- Package body -->
      <rect x="0" y="0" width={mcu.size} height={mcu.size} rx="4" fill="url(#mcu-body)" stroke="#2a2a2a" stroke-width="1" />
      <rect x="5" y="5" width={mcu.size - 10} height={mcu.size - 10} rx="2" fill="url(#mcu-die)" stroke="#1a1a1a" stroke-width="0.5" />

      <!-- Die outline + bond pad hint -->
      <rect x="18" y="18" width={mcu.size - 36} height={mcu.size - 36} rx="1" fill="none" stroke="#333" stroke-width="0.5" opacity="0.6" />
      <rect x="24" y="24" width={mcu.size - 48} height={mcu.size - 48} rx="1" fill="#050505" opacity="0.8" />

      <!-- Pin 1 dot -->
      <circle cx="14" cy="14" r="3.5" fill="#111" stroke="#444" stroke-width="0.5" />
      <circle cx="14" cy="14" r="1.5" fill="#666" />

      <!-- Specular highlight -->
      <path
        d={`M 8 8 L ${mcu.size - 20} 8 Q ${mcu.size - 8} 8 ${mcu.size - 8} 20 L ${mcu.size - 8} ${mcu.size - 28} Q ${mcu.size - 8} ${mcu.size - 8} ${mcu.size - 20} ${mcu.size - 8} L 20 ${mcu.size - 8} Q 8 ${mcu.size - 8} 8 ${mcu.size - 20} Z`}
        fill="#ffffff"
        opacity="0.04"
      />

      <!-- Silkscreen -->
      <text x={mcu.size / 2} y={mcu.size / 2 + 4} text-anchor="middle" fill="#0891b2" opacity="0.55" font-size="13" font-weight="bold" font-family="monospace">STM32</text>
      <text x={mcu.size / 2} y={mcu.size / 2 + 18} text-anchor="middle" fill="#ffffff" opacity="0.2" font-size="7" font-family="monospace">U1 · LQFP-64</text>
    </g>

    <!-- Animated signal traces -->
    <g fill="none" stroke-linecap="round" stroke-linejoin="round" filter="url(#pcb-signal-glow)">
      <path d={traces.xtal} class="pcb-signal" style="animation-delay: 0s" />
      <path d={traces.can} class="pcb-signal" style="animation-delay: 0.3s" />
      <path d={traces.usb} class="pcb-signal" style="animation-delay: 0.6s" />
      <path d={traces.ldo} class="pcb-signal" style="animation-delay: 0.9s" />
      <path d={traces.debug} class="pcb-signal" style="animation-delay: 0.15s" />
      <path d={traces.caps} class="pcb-signal" style="animation-delay: 0.45s" />
      <path d={traces.reg} class="pcb-signal" style="animation-delay: 0.75s" />
      <path d={traces.passives} class="pcb-signal" style="animation-delay: 1.05s" />
    </g>

    <!-- Traveling pulse dots -->
    <g filter="url(#pcb-glow)">
      <circle r="3.5" fill="#22d3ee">
        <animateMotion dur="2.2s" repeatCount="indefinite" path={traces.xtal} />
      </circle>
      <circle r="3.5" fill="#22d3ee">
        <animateMotion dur="2.4s" repeatCount="indefinite" begin="0.35s" path={traces.can} />
      </circle>
      <circle r="3.5" fill="#22d3ee">
        <animateMotion dur="2.6s" repeatCount="indefinite" begin="0.7s" path={traces.usb} />
      </circle>
      <circle r="3.5" fill="#22d3ee">
        <animateMotion dur="2.3s" repeatCount="indefinite" begin="1s" path={traces.ldo} />
      </circle>
      <circle r="3" fill="#67e8f9">
        <animateMotion dur="2s" repeatCount="indefinite" begin="0.2s" path={traces.debug} />
      </circle>
      <circle r="3" fill="#67e8f9">
        <animateMotion dur="2.5s" repeatCount="indefinite" begin="0.55s" path={traces.caps} />
      </circle>
    </g>

    <!-- Silkscreen -->
    <text x={view.w / 2} y="458" text-anchor="middle" fill="#ffffff" opacity="0.16" font-size="9" font-family="monospace" letter-spacing="1">
      ALEXIOT-CTRL · Rev 1.2 · HASL
    </text>
  </svg>
</figure>

<style>
  .pcb-hero {
    width: 100%;
    margin: 0;
  }

  .pcb-hero__svg {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    border-radius: inherit;
  }

  .pcb-signal {
    stroke: #22d3ee;
    stroke-width: 2.5;
    stroke-dasharray: 8 20;
    animation: pcb-signal-flow 1.8s linear infinite;
  }

  .pcb-pin {
    animation: pcb-pin-pulse 2.4s ease-in-out infinite;
  }

  @keyframes pcb-signal-flow {
    to {
      stroke-dashoffset: -28;
    }
  }

  @keyframes pcb-pin-pulse {
    0%,
    100% {
      fill: #c9a227;
    }
    40%,
    60% {
      fill: #22d3ee;
    }
  }
</style>
