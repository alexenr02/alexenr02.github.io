---
// Simple group icons for skill layouts (inline SVG)

interface Props {
  group: string;
  class?: string;
}

const { group, class: className } = Astro.props;
const g = group.toLowerCase();
---

<span class:list={['skill-icon', className]} aria-hidden="true" data-group={g}>
  {
    g === 'lang' && (
      <svg viewBox="0 0 32 32" fill="none">
        <path
          d="M8 6h12l4 4v16H8V6z"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linejoin="round"
        />
        <path d="M20 6v4h4M12 14h8M12 18h8M12 22h5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
      </svg>
    )
  }
  {
    g === 'mcu' && (
      <svg viewBox="0 0 32 32" fill="none">
        <rect x="8" y="8" width="16" height="16" rx="2" stroke="currentColor" stroke-width="1.75" />
        <rect x="12" y="12" width="8" height="8" fill="currentColor" opacity="0.35" />
        <path
          d="M12 4v4M16 4v4M20 4v4M12 24v4M16 24v4M20 24v4M4 12h4M4 16h4M4 20h4M24 12h4M24 16h4M24 20h4"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
        />
      </svg>
    )
  }
  {
    g === 'rtos' && (
      <svg viewBox="0 0 32 32" fill="none">
        <circle cx="16" cy="16" r="9" stroke="currentColor" stroke-width="1.75" />
        <path d="M16 10v6l4 2" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
        <path d="M7 16h2M23 16h2M16 7v2M16 23v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    )
  }
  {
    g === 'bus' && (
      <svg viewBox="0 0 32 32" fill="none">
        <path d="M4 12h24M4 20h24" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
        <circle cx="10" cy="12" r="2.5" fill="currentColor" />
        <circle cx="22" cy="12" r="2.5" fill="currentColor" />
        <circle cx="16" cy="20" r="2.5" fill="currentColor" />
      </svg>
    )
  }
  {
    g === 'method' && (
      <svg viewBox="0 0 32 32" fill="none">
        <path d="M8 8h16v4H8zM8 14h16v4H8zM8 20h10v4H8z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round" />
        <path d="M22 22l3 3 5-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    )
  }
  {
    g === 'tool' && (
      <svg viewBox="0 0 32 32" fill="none">
        <path
          d="M18 8l6 6-8 8H10v-6l8-8z"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linejoin="round"
        />
        <path d="M14 18l4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
      </svg>
    )
  }
  {
    (g === 'lab' || !['lang', 'mcu', 'rtos', 'bus', 'method', 'tool'].includes(g)) && (
      <svg viewBox="0 0 32 32" fill="none">
        <path
          d="M12 6h8v6l4 12H8l4-12V6z"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linejoin="round"
        />
        <path d="M12 6h8M11 18h10" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
      </svg>
    )
  }
</span>

<style>
  .skill-icon {
    display: inline-flex;
    width: 1.75rem;
    height: 1.75rem;
    color: #108474;
  }

  .skill-icon :global(svg) {
    width: 100%;
    height: 100%;
  }
</style>
