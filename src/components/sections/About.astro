---
// Option C: thin about band — one sentence, resume, links

import about from '../../content/about/about.json';
import { SITE, SOCIAL_LINKS } from '@lib/constants';

const aboutPhoto = about.photo?.trim() || undefined;
---

<section id="about" class="about-band scroll-mt-[var(--nav-height)] border-y border-border py-10 md:py-12">
  <div class="container mx-auto px-4">
    <div class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between md:gap-12">
      <div class="flex items-start gap-4 md:items-center">
        <div
          class="flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-full border border-border bg-card md:h-20 md:w-20"
        >
          {
            aboutPhoto ? (
              <img
                src={aboutPhoto}
                alt={about.photoAlt || 'Portrait'}
                class="h-full w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <span class="font-mono text-lg font-semibold text-foreground" aria-hidden="true">
                AE
              </span>
            )
          }
        </div>
        <div class="max-w-xl">
          <p class="text-lg leading-snug text-foreground md:text-xl">{about.tagline}</p>
          <p class="mt-1 text-sm text-secondary">{about.subheading}</p>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
        <a
          href={about.resume.path}
          download
          class="font-medium text-foreground underline-offset-4 hover:underline"
        >
          {about.resume.buttonLabel}
        </a>
        <a
          href={`mailto:${SITE.email}`}
          class="text-secondary underline-offset-4 hover:text-foreground hover:underline"
        >
          Email
        </a>
        <a
          href={SOCIAL_LINKS.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="text-secondary underline-offset-4 hover:text-foreground hover:underline"
        >
          LinkedIn
        </a>
        <a
          href={SOCIAL_LINKS.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-secondary underline-offset-4 hover:text-foreground hover:underline"
        >
          GitHub
        </a>
      </div>
    </div>
  </div>
</section>
