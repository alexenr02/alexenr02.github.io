---
// About — Option A metrics + Rokid product-page metric style
// Editable: src/content/about/about.json

import about from '../../content/about/about.json';
import { Download } from 'lucide-svelte';

const aboutPhoto = about.photo?.trim() || undefined;
---

<section id="about" class="scroll-mt-[var(--nav-height)] py-section">
  <div class="container mx-auto px-4">
    <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="mb-2 font-mono text-[11px] uppercase tracking-[0.22em] text-secondary">About</p>
        <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
          {about.sectionTitle}
        </h2>
      </div>
      <a
        href={about.resume.path}
        download
          class="inline-flex items-center gap-2 rounded-full bg-primary px-5 py-2.5 text-sm font-medium text-white transition-opacity hover:opacity-90"
      >
        <Download class="h-4 w-4" aria-hidden="true" />
        {about.resume.buttonLabel}
      </a>
    </div>

    <div class="grid items-start gap-10 lg:grid-cols-[minmax(0,15rem)_1fr] lg:gap-16">
      <div class="flex flex-col items-center gap-4 lg:items-start">
        <div
          class="relative flex h-40 w-40 items-center justify-center overflow-hidden rounded-2xl bg-background md:h-48 md:w-48"
        >
          {
            aboutPhoto ? (
              <img
                src={aboutPhoto}
                alt={about.photoAlt || 'About photo'}
                class="h-full w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <span class="text-4xl font-bold tracking-tight text-primary" aria-hidden="true">
                AE
              </span>
            )
          }
        </div>
        <p class="text-center text-sm text-secondary lg:text-left">{about.subheading}</p>
      </div>

      <div class="space-y-8">
        <p class="max-w-2xl text-xl font-medium leading-snug text-foreground md:text-2xl">
          {about.tagline}
        </p>

        <!-- Rokid-style big metrics -->
        <div class="grid gap-3 sm:grid-cols-3">
          {
            about.metrics.map((metric) => (
              <div class="metric-chip rounded-2xl bg-background px-5 py-6">
                <p class="text-3xl font-bold tracking-tight text-primary md:text-4xl">
                  {metric.value}
                </p>
                <p class="mt-2 text-sm leading-snug text-secondary">{metric.label}</p>
              </div>
            ))
          }
        </div>

        <div class="border-t border-border pt-6">
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-secondary">Education</p>
          <p class="mt-2 font-medium text-foreground">{about.education.school}</p>
          <p class="mt-0.5 text-sm text-secondary">{about.education.degree}</p>
          <p class="mt-1 text-xs text-secondary">{about.education.note}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .metric-chip {
    background:
      linear-gradient(var(--color-card-bg), var(--color-card-bg)) padding-box,
      var(--gradient-soft) border-box;
    border: 1px solid transparent;
  }
</style>
