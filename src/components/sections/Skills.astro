---
// Skills — Accent rail + Terminal tips with context images

import skills from '../../content/skills/skills.json';

function tipId(name: string) {
  return `skill-tip-${name.replace(/[^a-z0-9]+/gi, '-').toLowerCase()}`;
}
---

<section id="skills" class="skills-section scroll-mt-[var(--nav-height)] py-section">
  <div class="container mx-auto px-4">
    <p class="mb-2 font-mono text-[11px] uppercase tracking-[0.22em] text-secondary">Stack</p>
    <h2 class="mb-8 text-3xl font-bold tracking-tight text-foreground md:text-4xl">
      {skills.sectionTitle}
    </h2>

    <ul class="skills-grid">
      {
        skills.highlights.map((item) => (
          <li class="skills-card">
            <button type="button" class="skills-card__hit" aria-describedby={tipId(item.name)}>
              <span class="skills-card__group">{item.group}</span>
              <span class="skills-card__name">{item.name}</span>
            </button>
            <div id={tipId(item.name)} class="skills-card__tip" role="tooltip">
              <div class="skills-card__tip-media">
                <img
                  class="skills-card__tip-img"
                  src={item.image}
                  alt=""
                  width="640"
                  height="360"
                  decoding="async"
                  data-no-border
                />
              </div>
              <div class="skills-card__tip-copy">
                <p class="skills-card__tip-label">Industry usage</p>
                <p class="skills-card__tip-body">{item.usage}</p>
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .skills-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .skills-card {
    position: relative;
  }

  .skills-card__hit {
    display: flex;
    width: 100%;
    min-height: 4.75rem;
    flex-direction: column;
    gap: 0.4rem;
    border: none;
    border-radius: 0.85rem;
    border-left: 4px solid #108474;
    background: #fff;
    padding: 1rem 1rem 1rem 1.15rem;
    text-align: left;
    cursor: default;
    box-shadow: 0 1px 0 rgba(17, 50, 75, 0.06);
    transition:
      box-shadow 0.18s ease,
      transform 0.18s ease;
  }

  .skills-card__hit:hover,
  .skills-card__hit:focus-visible {
    box-shadow: 0 8px 24px rgba(17, 50, 75, 0.12);
    transform: translateY(-1px);
  }

  .skills-card__hit:focus-visible {
    outline: 3px solid var(--color-focus);
    outline-offset: 2px;
  }

  .skills-card__group {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #5a6b7a;
  }

  .skills-card__name {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-text);
  }

  .skills-card__tip {
    position: absolute;
    left: 0;
    bottom: calc(100% + 0.55rem);
    z-index: 30;
    width: min(18.5rem, calc(100vw - 2rem));
    overflow: hidden;
    border-radius: 0.35rem;
    border: 1px solid #2a4558;
    background: #0e1a24;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.35);
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition:
      opacity 0.16s ease,
      transform 0.16s ease,
      visibility 0.16s ease;
    pointer-events: none;
  }

  .skills-card__tip::after {
    content: '';
    position: absolute;
    left: 1.25rem;
    top: 100%;
    border: 6px solid transparent;
    border-top-color: #0e1a24;
  }

  .skills-card__tip-media {
    background: #0e1a24;
    border-bottom: 1px solid #2a4558;
  }

  .skills-card__tip-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: contain;
    object-position: center;
  }

  .skills-card__tip-copy {
    padding: 0.75rem 0.9rem 0.9rem;
  }

  .skills-card__tip-label {
    margin-bottom: 0.35rem;
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #7eb8a8;
  }

  .skills-card__tip-label::before {
    content: '> ';
  }

  .skills-card__tip-body {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    line-height: 1.45;
    color: #c4dfff;
  }

  .skills-card:hover .skills-card__tip,
  .skills-card:focus-within .skills-card__tip {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  @media (min-width: 768px) {
    .skills-card:nth-child(-n + 3) .skills-card__tip {
      bottom: auto;
      top: calc(100% + 0.55rem);
    }

    .skills-card:nth-child(-n + 3) .skills-card__tip::after {
      top: auto;
      bottom: 100%;
      border-top-color: transparent;
      border-bottom-color: #0e1a24;
    }
  }

  [data-theme='dark'] .skills-card__hit {
    background: var(--color-card-bg);
  }

  @media (prefers-reduced-motion: reduce) {
    .skills-card__hit,
    .skills-card__tip {
      transition: none;
    }
  }
</style>
