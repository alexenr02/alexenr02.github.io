---
// Skills — locked carousel layout

import skills from '../../content/skills/skills.json';
import SkillsCarousel from '@components/skills/SkillsCarousel.svelte';
---

<section id="skills" class="skills-section scroll-mt-[var(--nav-height)] py-section">
  <div class="container mx-auto px-4">
    <p class="mb-2 font-mono text-[11px] uppercase tracking-[0.22em] text-secondary">Stack</p>
    <h2 class="mb-8 text-3xl font-bold tracking-tight text-foreground md:text-4xl">
      {skills.sectionTitle}
    </h2>

    <SkillsCarousel client:load items={skills.highlights} />
  </div>
</section>
