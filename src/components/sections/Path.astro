---
// Option B: Path — school → roles → outcomes as signal nodes
// Merges about + experience into one diagram

import { getCollection } from 'astro:content';
import about from '../../content/about/about.json';

const entries = await getCollection('experience');
const roles = entries.sort((a, b) => (b.data.order ?? 99) - (a.data.order ?? 99)); // chronological: oldest first visually top→bottom? Actually path should be past→present. order 3 is JD (oldest), 1 is Carrier (newest). So reverse order for timeline.

const timeline = [...roles].sort((a, b) => (b.data.order ?? 99) - (a.data.order ?? 99));

function yearOf(date: Date): string {
  return String(date.getFullYear());
}

function rangeLabel(start: Date, end?: Date): string {
  if (!end) return `${yearOf(start)}–`;
  return `${yearOf(start)}–${yearOf(end)}`;
}
---

<section id="path" class="path-section scroll-mt-[var(--nav-height)] py-section">
  <div class="container mx-auto px-4">
    <div class="mb-3 flex items-center gap-3">
      <span class="path-section__ch font-mono text-xs uppercase tracking-[0.2em] text-secondary"
        >CH1</span
      >
      <h2 class="text-3xl font-bold text-foreground md:text-4xl">Path</h2>
    </div>
    <p class="mb-12 max-w-lg text-secondary">{about.tagline}</p>

    <div class="path-diagram relative mx-auto max-w-3xl">
      <!-- Vertical signal bus -->
      <div class="path-diagram__bus" aria-hidden="true"></div>

      <!-- Education node -->
      <article class="path-node path-node--edu">
        <div class="path-node__pin" aria-hidden="true"></div>
        <div class="path-node__body">
          <p class="path-node__meta">Education · 2023</p>
          <h3 class="path-node__title">{about.education.school}</h3>
          <p class="path-node__detail">{about.education.degree}</p>
        </div>
      </article>

      <!-- Role nodes -->
      {
        timeline.map((entry) => (
          <article class="path-node">
            <div class="path-node__pin" aria-hidden="true"></div>
            <div class="path-node__body">
              <div class="flex flex-wrap items-center gap-3">
                {entry.data.logo && (
                  <div class="flex h-9 w-9 shrink-0 items-center justify-center overflow-hidden rounded border border-border bg-white p-0.5">
                    <img
                      src={entry.data.logo}
                      alt=""
                      loading="lazy"
                      decoding="async"
                      class="h-full w-full object-contain"
                    />
                  </div>
                )}
                <div class="min-w-0">
                  <p class="path-node__meta">
                    {rangeLabel(entry.data.startDate, entry.data.endDate)}
                    {entry.data.location && ` · ${entry.data.location.split(',')[0]}`}
                  </p>
                  <h3 class="path-node__title">{entry.data.company}</h3>
                  <p class="path-node__detail">{entry.data.position}</p>
                </div>
              </div>

              {entry.data.responsibilities && entry.data.responsibilities.length > 0 && (
                <details class="path-node__details mt-3">
                  <summary>Signal detail</summary>
                  <ul class="mt-2 space-y-1.5">
                    {entry.data.responsibilities.slice(0, 4).map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </details>
              )}
            </div>
          </article>
        ))
      }

      <!-- Outcomes node -->
      <article class="path-node path-node--out">
        <div class="path-node__pin path-node__pin--accent" aria-hidden="true"></div>
        <div class="path-node__body">
          <p class="path-node__meta">Outcomes</p>
          <div class="mt-3 grid gap-3 sm:grid-cols-3">
            {
              about.metrics.map((metric) => (
                <div class="path-metric">
                  <p class="path-metric__value">{metric.value}</p>
                  <p class="path-metric__label">{metric.label}</p>
                </div>
              ))
            }
          </div>
          <a
            href={about.resume.path}
            download
            class="mt-5 inline-flex items-center gap-2 font-mono text-xs uppercase tracking-wider text-foreground underline-offset-4 hover:underline"
          >
            Resume PDF
          </a>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .path-diagram {
    padding-left: 1.75rem;
  }

  .path-diagram__bus {
    position: absolute;
    left: 0.55rem;
    top: 0.75rem;
    bottom: 0.75rem;
    width: 2px;
    background: linear-gradient(
      180deg,
      var(--color-border) 0%,
      var(--color-signal, #c4892a) 50%,
      var(--color-border) 100%
    );
  }

  .path-node {
    position: relative;
    margin-bottom: 1.75rem;
  }

  .path-node:last-child {
    margin-bottom: 0;
  }

  .path-node__pin {
    position: absolute;
    left: -1.42rem;
    top: 1.15rem;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    border: 2px solid var(--color-signal, #c4892a);
    background: var(--color-bg);
  }

  .path-node__pin--accent {
    background: var(--color-signal, #c4892a);
  }

  .path-node__body {
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-signal, #c4892a);
    background: var(--color-card-bg);
    padding: 1rem 1.15rem;
  }

  .path-node__meta {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-secondary);
  }

  .path-node__title {
    margin-top: 0.15rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .path-node__detail {
    margin-top: 0.15rem;
    font-size: 0.9rem;
    color: var(--color-secondary);
  }

  .path-node__details summary {
    cursor: pointer;
    list-style: none;
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-secondary);
  }

  .path-node__details summary::-webkit-details-marker {
    display: none;
  }

  .path-node__details ul {
    border-left: 1px solid var(--color-border);
    padding-left: 0.85rem;
  }

  .path-node__details li {
    font-size: 0.85rem;
    line-height: 1.45;
    color: var(--color-secondary);
  }

  .path-metric {
    border: 1px dashed var(--color-border);
    padding: 0.75rem;
  }

  .path-metric__value {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .path-metric__label {
    margin-top: 0.25rem;
    font-size: 0.75rem;
    line-height: 1.35;
    color: var(--color-secondary);
  }

  @media (min-width: 768px) {
    .path-diagram {
      padding-left: 2.25rem;
    }

    .path-diagram__bus {
      left: 0.7rem;
    }

    .path-node__pin {
      left: -1.78rem;
    }
  }
</style>
