---
// Experience — Option A compact rail + Option B path pins, Rokid cards

import { getCollection } from 'astro:content';

const entries = await getCollection('experience');
const sorted = entries.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

function formatRange(start: Date, end?: Date): string {
  const startYear = start.getFullYear();
  if (!end) return `${startYear}–Now`;
  const endYear = end.getFullYear();
  if (startYear === endYear) return `${startYear}`;
  return `${startYear}–${endYear}`;
}
---

<section id="experience" class="scroll-mt-[var(--nav-height)] py-section">
  <div class="container mx-auto px-4">
    <p class="mb-2 font-mono text-[11px] uppercase tracking-[0.22em] text-secondary">Path</p>
    <h2 class="mb-10 text-3xl font-bold tracking-tight text-foreground md:text-4xl">Experience</h2>

    <ol class="experience-rail relative space-y-0">
      {
        sorted.map((entry, index) => (
          <li class="experience-rail__item relative pl-6 md:pl-0">
            {index < sorted.length - 1 && (
              <div
                class="absolute left-[0.35rem] top-12 bottom-0 w-px bg-border md:left-[1.45rem]"
                aria-hidden="true"
              />
            )}

            <div class="flex gap-4 pb-8 md:gap-6 md:pb-10">
              <div class="relative z-[1] shrink-0">
                {entry.data.logo ? (
                  <div class="flex h-10 w-10 items-center justify-center overflow-hidden rounded-xl border border-border bg-white p-1 md:h-12 md:w-12">
                    <img
                      src={entry.data.logo}
                      alt={entry.data.logoAlt ?? `${entry.data.company} logo`}
                      loading="lazy"
                      decoding="async"
                      class="h-full w-full object-contain"
                    />
                  </div>
                ) : (
                  <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-mist font-mono text-xs text-secondary md:h-12 md:w-12">
                    {formatRange(entry.data.startDate, entry.data.endDate).slice(0, 2)}
                  </div>
                )}
              </div>

              <div class="min-w-0 flex-1 rounded-2xl bg-background p-5 md:p-6">
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                  <h3 class="text-lg font-semibold text-foreground">{entry.data.position}</h3>
                  <span class="font-mono text-xs text-secondary">
                    {formatRange(entry.data.startDate, entry.data.endDate)}
                  </span>
                </div>
                <p class="mt-0.5 text-sm font-medium text-primary">
                  {entry.data.company}
                  {entry.data.location && (
                    <span class="font-normal text-secondary"> · {entry.data.location}</span>
                  )}
                </p>

                {entry.data.technologies && entry.data.technologies.length > 0 && (
                  <p class="mt-2 font-mono text-xs leading-relaxed text-secondary">
                    {entry.data.technologies.slice(0, 6).join(' · ')}
                    {entry.data.technologies.length > 6 &&
                      ` · +${entry.data.technologies.length - 6}`}
                  </p>
                )}

                {entry.data.responsibilities && entry.data.responsibilities.length > 0 && (
                  <details class="experience-details group mt-3">
                    <summary class="cursor-pointer list-none font-mono text-[11px] uppercase tracking-[0.16em] text-signal transition-colors hover:text-primary">
                      <span class="inline-flex items-center gap-1.5">
                        <span
                          class="inline-block transition-transform group-open:rotate-90"
                          aria-hidden="true"
                        >
                          ▸
                        </span>
                        Highlights
                      </span>
                    </summary>
                    <ul class="mt-3 space-y-2 border-l-2 border-signal/30 pl-4">
                      {entry.data.responsibilities.map((item) => (
                        <li class="text-sm leading-relaxed text-secondary">{item}</li>
                      ))}
                    </ul>
                  </details>
                )}
              </div>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .experience-details summary::-webkit-details-marker {
    display: none;
  }
</style>
