---
// Contact — Option C: minimal close

import { SITE, SOCIAL_LINKS } from '@lib/constants';
---

<section id="contact" class="scroll-mt-[var(--nav-height)] py-16 md:py-20">
  <div class="container mx-auto px-4 text-center">
    <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">Get in touch</h2>
    <p class="mx-auto mt-3 max-w-md text-secondary">Open to roles and collaborations.</p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-sm font-medium">
      <a
        href={`mailto:${SITE.email}`}
        class="text-foreground underline-offset-4 hover:underline"
      >
        {SITE.email}
      </a>
      <a
        href={SOCIAL_LINKS.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-secondary underline-offset-4 hover:text-foreground hover:underline"
      >
        LinkedIn
      </a>
      <a
        href={SOCIAL_LINKS.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-secondary underline-offset-4 hover:text-foreground hover:underline"
      >
        GitHub
      </a>
    </div>
  </div>
</section>
