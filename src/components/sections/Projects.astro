---
// Option C: gallery — large covers, title + tech only

import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const all = await getCollection('projects', ({ data }) => !data.draft && !data.archived);

const projects = all.sort((a, b) => {
  const orderDiff = (a.data.order ?? 99) - (b.data.order ?? 99);
  if (orderDiff !== 0) return orderDiff;
  return b.data.date.getTime() - a.data.date.getTime();
});
---

<section id="work" class="scroll-mt-[var(--nav-height)] py-8 md:py-12">
  <div class="container mx-auto px-4">
    <h2 class="sr-only">Work</h2>

    {
      projects.length === 0 ? (
        <p class="text-lg text-secondary">Projects coming soon.</p>
      ) : (
        <ul class="gallery flex flex-col gap-6 md:gap-8">
          {projects.map((project, index) => (
            <li>
              <a
                href={`/projects/${project.slug}`}
                class:list={[
                  'gallery__item group relative block overflow-hidden',
                  index === 0 ? 'min-h-[70vh] md:min-h-[78vh]' : 'min-h-[55vh] md:min-h-[62vh]',
                ]}
              >
                {project.data.thumbnail ? (
                  <Image
                    src={project.data.thumbnail}
                    alt=""
                    width={1600}
                    height={900}
                    class="absolute inset-0 h-full w-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-[1.03]"
                    data-no-border
                    loading={index === 0 ? 'eager' : 'lazy'}
                  />
                ) : (
                  <div class="absolute inset-0 bg-gradient-to-br from-neutral-800 to-neutral-950" />
                )}

                <div
                  class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/25 to-black/10"
                  aria-hidden="true"
                />

                <div class="absolute inset-0 flex flex-col justify-end p-6 md:p-10">
                  <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-white/65">
                    {project.data.category}
                  </p>
                  <h3 class="mt-2 max-w-3xl text-3xl font-semibold tracking-tight text-white md:text-5xl">
                    {project.data.title}
                  </h3>
                  <p class="mt-3 flex flex-wrap gap-x-3 gap-y-1 font-mono text-xs text-white/70 md:text-sm">
                    {project.data.techStack.slice(0, 5).map((tech) => (
                      <span>{tech}</span>
                    ))}
                  </p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</section>

<style>
  .gallery__item {
    background: #111;
  }
</style>
