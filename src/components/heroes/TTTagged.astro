---
// 5 — Tagged Type: Type Takeover navy + Orbit floating tech tags

import ChipAnimation from '@components/common/ChipAnimation.svelte';
import hero from '../../content/hero/hero.json';

const parts = hero.name.split(' ');
const first = parts[0] ?? hero.name;
const rest = parts.slice(1).join(' ');

const tags = ['CAN / J1939', 'HIL', 'embOS · MQX', 'Bring-up', 'Cortex-M', 'V-model'];
---

<section class="tt5 relative min-h-[100dvh] overflow-hidden" style="background: #11324b;">
  <div class="absolute inset-0 opacity-45" aria-hidden="true">
    <ChipAnimation client:visible />
  </div>
  <div class="tt5__wash absolute inset-0" aria-hidden="true"></div>

  <div class="relative z-10 flex min-h-[100dvh] flex-col justify-between px-4 py-28 md:py-24">
    <div class="container mx-auto flex flex-1 flex-col justify-center">
      <p class="mb-4 font-mono text-[11px] uppercase tracking-[0.28em] text-white/45 md:mb-6">
        {hero.subtitle}
      </p>
      <h1 class="tt5__title font-bold tracking-tight text-white">
        <span class="block">{first}</span>
        {rest && <span class="block text-white/80">{rest}</span>}
      </h1>
      <div class="mt-8 flex flex-wrap gap-2">
        {
          tags.map((tag) => (
            <span class="rounded-full border border-white/20 bg-white/10 px-3 py-1.5 font-mono text-[10px] uppercase tracking-wider text-white/80 backdrop-blur-sm">
              {tag}
            </span>
          ))
        }
      </div>
    </div>

    <div class="container mx-auto flex flex-wrap gap-3 pt-8">
      <a href={hero.primaryCta.href} class="rounded-full bg-white px-7 py-3.5 text-sm font-medium text-[#11324b] hover:bg-white/90">{hero.primaryCta.label}</a>
      <a href={hero.secondaryCta.href} class="rounded-full border border-white/40 px-7 py-3.5 text-sm font-medium text-white hover:bg-white/10">{hero.secondaryCta.label}</a>
    </div>
  </div>
</section>

<style>
  .tt5__title {
    font-size: clamp(3.25rem, 12vw, 8.5rem);
    line-height: 0.88;
  }
  .tt5__wash {
    background: linear-gradient(180deg, rgba(17, 50, 75, 0.15) 0%, rgba(17, 50, 75, 0.88) 100%);
    pointer-events: none;
  }
</style>
