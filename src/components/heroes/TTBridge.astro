---
// 6 — Bridge: navy type block that bleeds into mist page color at the bottom

import ChipAnimation from '@components/common/ChipAnimation.svelte';
import hero from '../../content/hero/hero.json';

const parts = hero.name.split(' ');
const first = parts[0] ?? hero.name;
const rest = parts.slice(1).join(' ');
---

<section class="tt6 relative min-h-[100dvh] overflow-hidden bg-mist">
  <div class="tt6__navy absolute inset-x-0 top-0 h-[78%] overflow-hidden" style="background: #11324b;">
    <div class="absolute inset-0 opacity-50" aria-hidden="true">
      <ChipAnimation client:visible />
    </div>
    <div class="tt6__wash absolute inset-0" aria-hidden="true"></div>
  </div>

  <div class="relative z-10 flex min-h-[100dvh] flex-col justify-between px-4 py-28 md:py-24">
    <div class="container mx-auto flex flex-1 flex-col justify-center pt-4">
      <p class="mb-4 font-mono text-[11px] uppercase tracking-[0.28em] text-white/45 md:mb-6">
        {hero.subtitle}
      </p>
      <h1 class="tt6__title font-bold tracking-tight text-white">
        <span class="block">{first}</span>
        {rest && <span class="block text-white/80">{rest}</span>}
      </h1>
    </div>

    <div class="container mx-auto flex flex-wrap items-end justify-between gap-6 pt-8">
      <p class="max-w-sm text-sm text-secondary">Embedded problems, owned end-to-end.</p>
      <div class="flex flex-wrap gap-3">
        <a href={hero.primaryCta.href} class="rounded-full bg-primary px-7 py-3.5 text-sm font-medium text-white hover:opacity-90">{hero.primaryCta.label}</a>
        <a href={hero.secondaryCta.href} class="rounded-full border border-border bg-background px-7 py-3.5 text-sm font-medium text-foreground hover:border-primary">{hero.secondaryCta.label}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .tt6__title {
    font-size: clamp(3.25rem, 12vw, 8.5rem);
    line-height: 0.88;
  }
  .tt6__wash {
    background: linear-gradient(180deg, transparent 50%, #f2f4f4 100%);
    pointer-events: none;
  }
</style>
