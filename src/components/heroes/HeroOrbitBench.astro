---
// Hero 5 — Orbit Bench
// Chip centered on a soft stage; tech labels orbit like product feature tags

import ChipAnimation from '@components/common/ChipAnimation.svelte';
import hero from '../../content/hero/hero.json';

const tags = [
  { label: 'CAN / J1939', style: 'top-[12%] left-[8%]' },
  { label: 'HIL', style: 'top-[18%] right-[10%]' },
  { label: 'embOS · MQX', style: 'bottom-[28%] left-[6%]' },
  { label: 'Bring-up', style: 'bottom-[22%] right-[8%]' },
  { label: 'Cortex-M', style: 'top-[42%] left-[2%]' },
  { label: 'V-model', style: 'top-[48%] right-[4%]' },
];
---

<section
  class="hero-5 relative min-h-[100dvh] overflow-hidden bg-mist"
>
  <div class="hero-5__wash absolute inset-0" aria-hidden="true"></div>

  <div class="relative z-10 flex min-h-[100dvh] flex-col items-center justify-center px-4 py-28 text-center">
    <p class="mb-3 font-mono text-[11px] uppercase tracking-[0.28em] text-secondary">
      {hero.subtitle}
    </p>
    <h1 class="mb-8 max-w-3xl text-4xl font-bold tracking-tight text-foreground md:text-6xl">
      {hero.name}
    </h1>

    <div class="hero-5__orbit relative mx-auto w-full max-w-xl">
      <div class="relative mx-auto aspect-square w-[min(100%,22rem)] overflow-hidden rounded-full shadow-2xl md:w-[26rem]">
        <div class="absolute inset-0 bg-[#11324b]">
          <ChipAnimation client:visible />
        </div>
      </div>

      {
        tags.map((tag) => (
          <span
            class:list={[
              'hero-5__tag absolute hidden rounded-full border border-border bg-background/90 px-3 py-1.5 font-mono text-[10px] uppercase tracking-wider text-primary shadow-sm backdrop-blur sm:inline-block',
              tag.style,
            ]}
          >
            {tag.label}
          </span>
        ))
      }
    </div>

    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <a
        href={hero.primaryCta.href}
        class="rounded-full bg-primary px-7 py-3.5 text-sm font-medium text-white transition-opacity hover:opacity-90"
      >
        {hero.primaryCta.label}
      </a>
      <a
        href={hero.secondaryCta.href}
        class="rounded-full border border-border bg-background px-7 py-3.5 text-sm font-medium text-foreground transition-colors hover:border-primary"
      >
        {hero.secondaryCta.label}
      </a>
    </div>
  </div>
</section>

<style>
  .hero-5__wash {
    background: var(--gradient-soft);
    opacity: 0.4;
    pointer-events: none;
  }

  .hero-5__orbit :global(.chip-animation) {
    position: absolute !important;
    inset: 0;
    opacity: 1 !important;
    background: transparent !important;
  }

  .hero-5__orbit :global(.chip-animation__svg) {
    left: 0 !important;
    right: 0 !important;
    width: 100% !important;
    max-width: none !important;
    transform: none !important;
  }

  .hero-5__tag {
    animation: hero5-float 5s ease-in-out infinite;
  }

  .hero-5__tag:nth-child(odd) {
    animation-delay: 0.6s;
  }

  @keyframes hero5-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-5__tag {
      animation: none;
    }
  }
</style>
