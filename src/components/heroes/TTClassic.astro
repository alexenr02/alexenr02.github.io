---
// Type Takeover — name in Inter; title larger than name

import ChipAnimation from '@components/common/ChipAnimation.svelte';
import hero from '../../content/hero/hero.json';

const role = hero.subtitle.toUpperCase();
const roleParts = (() => {
  const words = role.split(' ');
  if (words.length <= 2) return [role];
  return [words.slice(0, -1).join(' '), words[words.length - 1]];
})();
---

<section class="tt1 relative min-h-[100dvh] overflow-hidden" style="background: #11324b;">
  <div class="absolute inset-0 opacity-50" aria-hidden="true">
    <ChipAnimation client:visible />
  </div>
  <div class="tt1__wash absolute inset-0" aria-hidden="true"></div>

  <div class="relative z-10 flex min-h-[100dvh] flex-col justify-between px-4 py-28 md:py-24">
    <div class="container mx-auto flex flex-1 flex-col justify-center">
      <h1 class="tt1__name mb-3 font-bold tracking-tight text-white md:mb-4">
        {hero.name}
      </h1>

      <p class="tt1__role font-bold tracking-tight text-white">
        {
          roleParts.map((line, i) => (
            <span class:list={['block', i > 0 && 'text-white/85']}>{line}</span>
          ))
        }
      </p>
    </div>

    <div class="container mx-auto flex flex-wrap items-end justify-between gap-6 pt-10">
      <p class="max-w-sm text-sm text-white/60">Embedded problems, owned end-to-end.</p>
      <div class="flex flex-wrap gap-3">
        <a
          href={hero.primaryCta.href}
          class="rounded-full bg-white px-7 py-3.5 text-sm font-medium text-[#11324b] hover:bg-white/90"
        >
          {hero.primaryCta.label}
        </a>
        <a
          href={hero.secondaryCta.href}
          class="rounded-full border border-white/40 px-7 py-3.5 text-sm font-medium text-white hover:bg-white/10"
        >
          {hero.secondaryCta.label}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .tt1__name {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(1.35rem, 3.2vw, 2.35rem);
    line-height: 1.1;
    font-weight: 700;
  }

  .tt1__role {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: clamp(2.75rem, 8vw, 5.75rem);
    line-height: 0.95;
    letter-spacing: 0.02em;
    font-weight: 700;
  }

  .tt1__wash {
    background:
      linear-gradient(
        180deg,
        rgba(17, 50, 75, 0.2) 0%,
        rgba(17, 50, 75, 0.55) 55%,
        rgba(17, 50, 75, 0.92) 100%
      ),
      radial-gradient(ellipse 60% 40% at 70% 40%, rgba(196, 223, 255, 0.15) 0%, transparent 60%);
    pointer-events: none;
  }
</style>
