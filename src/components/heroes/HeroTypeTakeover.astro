---
// Hero 4 — Type Takeover
// Name fills the viewport; chip peeks through the typography

import ChipAnimation from '@components/common/ChipAnimation.svelte';
import hero from '../../content/hero/hero.json';

const parts = hero.name.split(' ');
const first = parts[0] ?? hero.name;
const rest = parts.slice(1).join(' ');
---

<section
  class="hero-4 relative min-h-[100dvh] overflow-hidden"
  style="background: #11324b;"
>
  <div class="hero-4__chip absolute inset-0 opacity-50" aria-hidden="true">
    <ChipAnimation client:visible />
  </div>
  <div class="hero-4__wash absolute inset-0" aria-hidden="true"></div>

  <div class="relative z-10 flex min-h-[100dvh] flex-col justify-between px-4 py-28 md:py-24">
    <div class="container mx-auto flex-1 flex flex-col justify-center">
      <p class="mb-4 font-mono text-[11px] uppercase tracking-[0.28em] text-white/45 md:mb-6">
        {hero.subtitle}
      </p>
      <h1 class="hero-4__title font-bold tracking-tight text-white">
        <span class="block">{first}</span>
        {rest && <span class="block text-white/80">{rest}</span>}
      </h1>
    </div>

    <div class="container mx-auto flex flex-wrap items-end justify-between gap-6 pt-8">
      <p class="max-w-sm text-sm text-white/60">
        Embedded problems, owned end-to-end.
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href={hero.primaryCta.href}
          class="rounded-full bg-white px-7 py-3.5 text-sm font-medium text-[#11324b] transition-colors hover:bg-white/90"
        >
          {hero.primaryCta.label}
        </a>
        <a
          href={hero.secondaryCta.href}
          class="rounded-full border border-white/40 px-7 py-3.5 text-sm font-medium text-white transition-colors hover:border-white hover:bg-white/10"
        >
          {hero.secondaryCta.label}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-4__title {
    font-size: clamp(3.5rem, 14vw, 9.5rem);
    line-height: 0.88;
  }

  .hero-4__wash {
    background:
      linear-gradient(180deg, rgba(17, 50, 75, 0.2) 0%, rgba(17, 50, 75, 0.55) 55%, rgba(17, 50, 75, 0.92) 100%),
      radial-gradient(ellipse 60% 40% at 70% 40%, rgba(196, 223, 255, 0.15) 0%, transparent 60%);
    pointer-events: none;
  }
</style>
